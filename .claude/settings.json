{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "defaultMode": "acceptEdits",
    "allow": [
      "Bash(flutter *)",
      "Bash(dart *)",
      "Bash(git *)",
      "Bash(cd *)",
      "Bash(ls *)",
      "Bash(find *)",
      "Bash(grep *)",
      "Bash(rg *)",
      "Bash(cat *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(wc *)",
      "Bash(file *)",
      "Bash(du *)",
      "Bash(jq *)",
      "Bash(mkdir *)",
      "Bash(which *)"
    ],
    "deny": [
      "Edit(chatgpt_data/**)",
      "Write(chatgpt_data/**)"
    ]
  }
}
